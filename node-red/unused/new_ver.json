    {
        "id": "c6411159ce97c055",
        "type": "function",
        "z": "81df65c5080d9ae6",
        "name": "Format Cmd",
        "func": "\nif (msg.payload !== undefined && msg.payload !== null) {\n    var val = typeof msg.payload === 'object' ? msg.payload.value || msg.payload : msg.payload;\n    msg.payload = msg.topic + ':' + String(val);\n    return msg;\n}\nreturn null;\n",
        "outputs": 1,
        "x": 800,
        "y": 960,
        "wires": [ [ "b50fc4875f6bf43f" ] ]
    },
    {
        "id": "b44c3ded791ee9ca",
        "type": "function",
        "z": "81df65c5080d9ae6",
        "name": "Calculate Latency",
        "func": "\nif (msg.topic === \"stm32/commands\") {\n    flow.set(\"last_click_time\", Date.now());\n    return null;\n}\nconst lastClick = flow.get(\"last_click_time\");\nconst lastCmd = msg.payload.c;\n\nif (lastClick && lastCmd !== \"WAIT\") {\n    const latency = Date.now() - lastClick;\n    flow.set(\"last_click_time\", null);\n    return { payload: latency };\n}\nreturn null;\n",
        "outputs": 1,
        "x": 800,
        "y": 400,
        "wires": [ [ "7ead712f6cb4edf5" ] ]
    },
