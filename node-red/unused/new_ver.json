    {
        "id": "011f0074a21222d3",
        "type": "function",
        "z": "81df65c5080d9ae6",
        "name": "Parse & Calculate Stats",
        "func": "var p = msg.payload;\n\nvar msg_h = { \n    payload: p.h || 0, \n    topic: 'Health',\n    ui_update: { segments: [ { from: 0, color: \"#ea5353\" }, { from: 40, color: \"#ffc800\" }, { from: 80, color: \"#5cd65c\" } ] }\n};\n\nvar msg_s_gauge = { \n    payload: p.s || 0, \n    ui_update: { segments: [ { from: 0, color: \"#ea5353\" }, { from: p.sl || 30, color: \"#5cd65c\" }, { from: p.sh || 45, color: \"#ffc800\" } ] }\n};\nvar msg_s_chart = [ \n    { payload: p.s || 0, topic: 'Soil Moisture' }, \n    { payload: p.sl || 0, topic: 'Low Limit' }, \n    { payload: p.sh || 0, topic: 'High Limit' } \n];\n\nvar msg_t_gauge = { \n    payload: p.t || 0, \n    ui_update: { segments: [ { from: 0, color: \"#0094CE\" }, { from: p.tl || 28, color: \"#5cd65c\" }, { from: p.th || 30, color: \"#ea5353\" } ] }\n};\nvar msg_t_chart = [ \n    { payload: p.t || 0, topic: 'Temperature' }, \n    { payload: p.tl || 0, topic: 'Low Limit' }, \n    { payload: p.th || 0, topic: 'High Limit' } \n];\n\nvar msg_l_gauge = { \n    payload: p.l || 0, \n    ui_update: { segments: [ { from: 0, color: \"#ea5353\" }, { from: p.ll || 30, color: \"#5cd65c\" }, { from: p.lh || 50, color: \"#ffc800\" } ] }\n};\nvar msg_l_chart = [ \n    { payload: p.l || 0, topic: 'Light' }, \n    { payload: p.ll || 0, topic: 'Low Limit' }, \n    { payload: p.lh || 0, topic: 'High Limit' } \n];\n\nvar stat_h = { payload: \"Current Health: \" + (p.h||0) + \"%\" };\nvar stat_s = { payload: \"Current Soil: \" + (p.s||0) + \"%\" };\nvar stat_t = { payload: \"Current Temp: \" + (p.t||0) + \"°C\" };\nvar stat_l = { payload: \"Current Light: \" + (p.l||0) + \"%\" };\n\nvar pf_status = p.pf ? \"CRITICAL: PUMP ERROR!\" : \"System Normal\";\nvar am_status = p.am ? \"AUTO\" : \"MANUAL\";\nvar day_status = p.day ? \"DAY MODE\" : \"NIGHT MODE\";\nvar msg_status = { payload: pf_status + \" | \" + am_status + \" | \" + day_status };\nvar msg_dry = { payload: p.dv };\nvar msg_wet = { payload: p.wv };\nvar act_status = { payload: \"Pump: \" + (p.p ? \"ON\" : \"OFF\") + \" | Fan: \" + (p.f ? \"ON\" : \"OFF\") + \" | Light: \" + (p.pl ? \"ON\" : \"OFF\") };\n\n// Send thresholds as numbers so the Sliders visually update instantly\nvar txt_sl = { payload: p.sl || 0 };\nvar txt_sh = { payload: p.sh || 0 };\nvar txt_tl = { payload: p.tl || 0 };\nvar txt_th = { payload: p.th || 0 };\nvar txt_ll = { payload: p.ll || 0 };\nvar txt_lh = { payload: p.lh || 0 };\n\nreturn [\n    msg_h,              // Output 1: Health Gauge & Chart\n    msg_s_gauge,        // Output 2: ONLY Soil Gauge\n    msg_s_chart,        // Output 3: ONLY Soil Chart \n    msg_t_gauge,        // Output 4: ONLY Temp Gauge\n    msg_t_chart,        // Output 5: ONLY Temp Chart\n    msg_l_gauge,        // Output 6: ONLY Light Gauge\n    msg_l_chart,        // Output 7: ONLY Light Chart\n    stat_h, stat_s, stat_t, stat_l, // Outputs 8-11: Stats (Unwired to save UI space)\n    msg_status, msg_dry, msg_wet,   // Outputs 12-14: Status texts\n    txt_sl, txt_sh, txt_tl, txt_th, txt_ll, txt_lh, // Outputs 15-20: Routed straight to sliders\n    act_status          // Output 21: Actuators Status\n];",
        "outputs": 21,
        "x": 300,
        "y": 260,
        "wires": [
