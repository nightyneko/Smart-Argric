8d8f994dfb2eb8","type":"mqtt in","z":"fd84dde21ba11069","name":"STM32 Sensors","topic":"stm32/sensors","qos":"0","datatype":"json","broker":"e9adad2aa7674c97","inputs":0,"x":110,"y":500,"wires":[["342b830de88d880d","0712a58540a505a3"]]},{"id":"342b830de88d880d","type":"function","z":"fd84dde21ba11069","name":"Parse & Calculate Stats","func":"var p = msg.payload;\n\nvar msg_h = { \n    payload: p.h || 0, \n    topic: 'Health',\n    ui_update: { segments: [ { from: 0, color: \"#ea5353\" }, { from: 40, color: \"#ffc800\" }, { from: 80, color: \"#5cd65c\" } ] }\n};\n\nvar msg_s_gauge = { \n    payload: p.s || 0, \n    ui_update: { segments: [ { from: 0, color: \"#ea5353\" }, { from: p.sl || 30, color: \"#5cd65c\" }, { from: p.sh || 45, color: \"#ffc800\" } ] }\n};\nvar msg_s_chart = [ \n    { payload: p.s || 0, topic: 'Soil Moisture' }, \n    { payload: p.sl || 0, topic: 'Low Limit' }, \n    { payload: p.sh || 0, topic: 'High Limit' } \n];\n\nvar msg_t_gauge = { \n    payload: p.t || 0, \n    ui_update: { segments: [ { from: 0, color: \"#0094CE\" }, { from: p.tl || 28, color: \"#5cd65c\" }, { from: p.th || 30, color: \"#ea5353\" } ] }\n};\nvar msg_t_chart = [ \n    { payload: p.t || 0, topic: 'Temperature' }, \n    { payload: p.tl || 0, topic: 'Low Limit' }, \n    { payload: p.th || 0, topic: 'High Limit' } \n];\n\nvar msg_l_gauge = { \n    payload: p.l || 0, \n    ui_update: { segments: [ { from: 0, color: \"#ea5353\" }, { from: p.ll || 30, color: \"#5cd65c\" }, { from: p.lh || 50, color: \"#ffc800\" } ] }\n};\nvar msg_l_chart = [ \n    { payload: p.l || 0, topic: 'Light' }, \n    { payload: p.ll || 0, topic: 'Low Limit' }, \n    { payload: p.lh || 0, topic: 'High Limit' } \n];\n\nvar stat_h = { payload: \"Current Health: \" + (p.h||0) + \"%\" };\nvar stat_s = { payload: \"Current Soil: \" + (p.s||0) + \"%\" };\nvar stat_t = { payload: \"Current Temp: \" + (p.t||0) + \"°C\" };\nvar stat_l = { payload: \"Current Light: \" + (p.l||0) + \"%\" };\n\nvar pf_status = p.pf ? \"CRITICAL: PUMP ERROR!\" : \"System Normal\";\nvar am_status = p.am ? \"AUTO\" : \"MANUAL\";\nvar day_status = p.day ? \"DAY MODE\" : \"NIGHT MODE\";\nvar msg_status = { payload: pf_status + \" | \" + am_status + \" | \" + day_status };\nvar msg_dry = { payload: p.dv };\nvar msg_wet = { payload: p.wv };\nvar act_status = { payload: \"Pump: \" + (p.p ? \"ON\" : \"OFF\") + \" | Fan: \" + (p.f ? \"ON\" : \"OFF\") + \" | Light: \" + (p.pl ? \"ON\" : \"OFF\") };\n\n// Send thresholds as numbers so the Sliders visually update instantly\n// CHECK UI LOCKOUT: Has a slider been moved in the last 3000 milliseconds?\nvar lastMoveTime = flow.get(\"slider_lockout_time\") || 0;\nvar isLockedOut = (Date.now() - lastMoveTime) < 3000;\n\n// If locked out, return null so the sliders don't receive old data and jump back.\n// If NOT locked out, route the STM32 values to the sliders to keep them synced.\nvar txt_sl = isLockedOut ? null : { payload: p.sl || 0 };\nvar txt_sh = isLockedOut ? null : { payload: p.sh || 0 };\nvar txt_tl = isLockedOut ? null : { payload: p.tl || 0 };\nvar txt_th = isLockedOut ? null : { payload: p.th || 0 };\nvar txt_ll = isLockedOut ? null : { payload: p.ll || 0 };\nvar txt_lh = isLockedOut ? null : { payload: p.lh || 0 };\n\nreturn [\n    msg_h,              // Output 1: Health Gauge & Chart\n    msg_s_gauge,        // Output 2: ONLY Soil Gauge\n    msg_s_chart,        // Output 3: ONLY Soil Chart \n    msg_t_gauge,        // Output 4: ONLY Temp Gauge\n    msg_t_chart,        // Output 5: ONLY Temp Chart\n    msg_l_gauge,        // Output 6: ONLY Light Gauge\n    msg_l_chart,        // Output 7: ONLY Light Chart\n    stat_h, stat_s, stat_t, stat_l, // Outputs 8-11: Stats \n    msg_status, msg_dry, msg_wet,   // Outputs 12-14: Status texts\n    txt_sl, txt_sh, txt_tl, txt_th, txt_ll, txt_lh, // Outputs 15-20: Protected Sliders!\n    act_status          // Output 21: Actuators Status\n];","outputs":21,"timeout":"","noerr":0,"initialize":"","finalize":"","libs":[],"x":300,"y":260,"wires":[["149ba14273e6f0c6","0641c0d3b0732c74"],["f0d68825f5528294"],["e3d9426119bfe817"],["89221d10cb2f1350"],["488885d238182782"],["ba477af9bbb752b2"],["f7b195add30da906"],[],[],[],[],["c02f06f8e98262a0"],["00b2fe4bae302da2"],["30e3d5a649610207"],["caf2ff4bca56cbec"],["328a6e4cf15a19f1"],["3f43a89c6dcd8a58"],["ed5b88b08f7c5962"],["837ff786352159c5"],["bfab1dd8e63eb524"],["f686f76f0adf3d49"]]},{"id":"149ba14273e6f0c6","type":"ui-gauge","z":"fd84dde21ba11069","name":"Health %","group":"530dbf88cd8d56ad","order":1,"value":"payload","valueType":"msg","width":"3","height":"3","gtype":"gauge-half","gstyle":"needle","title":"Health","alwaysShowTitle":false,"floatingTitlePosition":"top-left","units":"%","icon":"","prefix":"","suffix":"","segments":[{"from":"0","color":"#ea5353"},{"from":"40.0","color":"#ffc800"},{"from":"70.0","color":"#5cd65c"}],"min":0,"max":100,"sizeThickness":16,"sizeGap":4,"sizeKeyThickness":8,"styleRounded":true,"styleGlow":false,"className":"","x":600,"y":40,"wires":[[]]},{"id":"f0d68825f5528294","type":"ui-gauge","z":"fd84dde21ba11069","name":"Soil %","group":"530dbf88cd8d56ad","order":2,"value":"payload","valueType":"msg","width":"3","height":"3","gtype":"gauge-half","gstyle":"needle","title":"Soil Moisture","alwaysShowTitle":false,"floatingTitlePosition":"top-left","units":"%","icon":"","prefix":"","suffix":"","segments":[{"from":"0","color":"#ea5353"},{"from":"40.0","color":"#ffc800"},{"from":"70.0","color":"#5cd65c"}],"min":0,"max":100,"sizeThickness":16,"sizeGap":4,"sizeKeyThickness":8,"styleRounded":true,"styleGlow":false,"className":"","x":600,"y":80,"wires":[[]]},{"id":"89221d10cb2f1350","type":"ui-gauge","z":"fd84dde21ba11069","name":"Temp C","group":"530dbf88cd8d56ad","order":3,"value":"payload","valueType":"msg","width":"3","height":"3","gtype":"gauge-half","gstyle":"needle","title":"Temperature","alwaysShowTitle":false,"floatingTitlePosition":"top-left","units":"°C","icon":"","prefix":"","suffix":"","segments":[{"