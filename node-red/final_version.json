[]},{"id":"d43c354a98c48a5f","type":"ui-text","z":"fd84dde21ba11069","group":"ff66c6f11a9c78ea","order":3,"width":"4","height":"1","name":"Latency Display","label":"Action Latency:","format":"{{msg.payload}} ms","layout":"row-spread","style":false,"font":"","fontSize":"","color":"#00ff00","wrapText":false,"className":"","value":"payload","valueType":"msg","x":1010,"y":380,"wires":[]},{"id":"41825b5e9f830213","type":"function","z":"fd84dde21ba11069","name":"Format Cmd","func":"if (msg.payload !== undefined && msg.payload !== null) {\n    var val = typeof msg.payload === 'object' ? msg.payload.value || msg.payload : msg.payload;\n    msg.payload = msg.topic + ':' + String(val);\n\n    // START UI LOCKOUT: Record the exact time the slider was moved\n    flow.set(\"slider_lockout_time\", Date.now());\n\n    return msg;\n}\nreturn null;","outputs":1,"timeout":"","noerr":0,"initialize":"","finalize":"","libs":[],"x":800,"y":960,"wires":[["86cd54f63bad217a"]]},{"id":"0712a58540a505a3","type":"function","z":"fd84dde21ba11069","name":"Calculate Latency","func":"// PHASE 1: Outbound Command Handling (From Dashboard to Node-RED)\nif (msg.topic === \"stm32/commands\") {\n    // The UI button sends a raw string or number (e.g., \"5\"), NOT a JSON object.\n    // We check that it is not null or empty.\n    if (msg.payload !== undefined && msg.payload !== null) {\n\n        // Start the timer\n        flow.set(\"last_click_time\", Date.now());\n\n        // Store the raw string (Force it to a String to guarantee a match later)\n        flow.set(\"pending_command\", String(msg.payload));\n    }\n\n    // Stop the outbound message from passing through to the latency text display\n    return null;\n}\n\n// PHASE 2: Inbound Response Handling (From STM32 back to Node-RED)\nif (msg.topic === \"stm32/sensors\") {\n\n    // Retrieve the active tracking variables\n    const lastClick = flow.get(\"last_click_time\");\n    const pendingCmd = flow.get(\"pending_command\");\n\n    // SAFETY CHECK: Ensure msg.payload is a valid object and contains the 'c' property\n    if (msg.payload && typeof msg.payload.c !== \"undefined\") {\n\n        // Extract the STM32's 'c' value and force it to a String (e.g., \"5\")\n        const incomingCmd = String(msg.payload.c);\n\n        // Check if the timer is running AND the STM32 confirms the exact command we sent\n        if (lastClick && pendingCmd && incomingCmd === pendingCmd) {\n\n            // Calculate the true round-trip latency\n            const latency = Date.now() - lastClick;\n\n            // Clear the tracking variables immediately so it doesn't fire twice\n            flow.set(\"last_click_time\", null);\n            flow.set(\"pending_command\", null);\n\n            // Output the latency to your UI text display node\n            return { payload: latency };\n        }\n    }\n\n    // Ignore routine sensor updates that do not match the pending command\n    return null;\n}\n\n// PHASE 3: Fallback \n// Ignore stray topics or background noise\nreturn null;","outputs":1,"timeout":"","noerr":0,"initialize":"","finalize":"","libs":[],"x":840,"y":320,"wires":[["d43c354a98c48a5f"]]},{"id":"86cd54f63bad217a","type":"mqtt out","z":"fd84dde21ba11069","name":"STM32 Commands","topic":"stm32/commands","qos":"0","retain":"false","respTopic":"","contentType":"","userProps":"","correl":"","expiry":"","broker":"e9adad2aa7674c97","x":1000,"y":600,"wires":[]},{"id":"da93d07427d76098","type":"inject","z":"fd84dde21ba11069","name":"Morning Schedule (06:00)","props":[{"p":"payload"}],"repeat":"","crontab":"","once":false,"onceDelay":"","topic":"","payload":"17","payloadType":"str","x":110,"y":340,"wires":[["86cd54f63bad217a"]]},{"id":"c09154252acf33e2","type":"inject","z":"fd84dde21ba11069","name":"Night Schedule (20:00)","props":[{"p":"payload"}],"repeat":"","crontab":"","once":false,"onceDelay":"","topic":"","payload":"18","payloadType":"str","x":100,"y":380,"wires":[["86cd54f63bad217a"]]},{"id":"d89b764029bf3e7e","typ