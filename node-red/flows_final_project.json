    {
        "id": "fn_threshold_format",
        "type": "function",
        "z": "tab_plant_iot_pro",
        "name": "Format Cmd",
        "func": "\nif (msg.payload !== undefined && msg.payload !== null) {\n    // Extract actual numeric value if payload is an object\n    var val = typeof msg.payload === 'object' ? msg.payload.value || msg.payload : msg.payload;\n    msg.payload = msg.topic + ':' + String(val);\n    return msg;\n}\nreturn null;\n",
        "outputs": 1,
        "x": 300,
        "y": 800,
        "wires": [
            [
                "mqtt_out_cmd_pro"
            ]
        ]
    },
