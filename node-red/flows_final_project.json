    {
        "id": "mqtt_in_sensors_pro",
        "type": "mqtt in",
        "z": "tab_plant_iot_pro",
        "name": "STM32 Sensors",
        "topic": "stm32/sensors",
        "qos": "0",
        "datatype": "json",
        "broker": "mqtt_broker_pro",
        "x": 100,
        "y": 200,
        "wires": [
            [
                "fn_telemetry_pro"
            ]
        ]
    },
    {
        "id": "fn_telemetry_pro",
        "type": "function",
        "z": "tab_plant_iot_pro",
        "name": "Parse & Calculate Stats",
        "func": "\nvar p = msg.payload;\n\n// Gauges with dynamic UI update properties for FlowFuse Dashboard\nvar msg_h = { \n    payload: p.h || 0, \n    topic: 'Health',\n    ui_update: { segments: [ { from: 0, color: \"#ea5353\" }, { from: 40, color: \"#ffc800\" }, { from: 80, color: \"#5cd65c\" } ] }\n};\n\nvar msg_s_gauge = { \n    payload: p.s || 0, \n    ui_update: { segments: [ { from: 0, color: \"#ea5353\" }, { from: p.sl || 30, color: \"#5cd65c\" }, { from: p.sh || 45, color: \"#ffc800\" } ] }\n};\nvar msg_s_chart = [ { payload: p.s || 0, topic: 'Soil Moisture' }, { payload: p.sl || 0, topic: 'Low Limit' }, { payload: p.sh || 0, topic: 'High Limit' } ];\n\n\nvar msg_t_gauge = { \n    payload: p.t || 0, \n    ui_update: { segments: [ { from: 0, color: \"#0094CE\" }, { from: p.tl || 28, color: \"#5cd65c\" }, { from: p.th || 30, color: \"#ea5353\" } ] }\n};\nvar msg_t_chart = [ { payload: p.t || 0, topic: 'Temperature' }, { payload: p.tl || 0, topic: 'Low Limit' }, { payload: p.th || 0, topic: 'High Limit' } ];\n\n\nvar msg_l_gauge = { \n    payload: p.l || 0, \n    ui_update: { segments: [ { from: 0, color: \"#ea5353\" }, { from: p.ll || 30, color: \"#5cd65c\" }, { from: p.lh || 50, color: \"#ffc800\" } ] }\n};\nvar msg_l_chart = [ { payload: p.l || 0, topic: 'Light' }, { payload: p.ll || 0, topic: 'Low Limit' }, { payload: p.lh || 0, topic: 'High Limit' } ];\n\n// Stats\nvar stat_h = { payload: \"Current Health: \" + (p.h||0) + \"%\" };\nvar stat_s = { payload: \"Current Soil: \" + (p.s||0) + \"%\" };\nvar stat_t = { payload: \"Current Temp: \" + (p.t||0) + \"\u00b0C\" };\nvar stat_l = { payload: \"Current Light: \" + (p.l||0) + \"%\" };\n\n// Status\nvar pf_status = p.pf ? \"CRITICAL: PUMP ERROR!\" : \"System Normal\";\nvar am_status = p.am ? \"AUTO\" : \"MANUAL\";\nvar day_status = p.day ? \"DAY MODE\" : \"NIGHT MODE\";\nvar msg_status = { payload: pf_status + \" | \" + am_status + \" | \" + day_status };\nvar msg_dry = { payload: p.dv };\nvar msg_wet = { payload: p.wv };\n\n\nvar act_status = { payload: \"Pump: \" + (p.p ? \"ON\" : \"OFF\") + \" | Fan: \" + (p.f ? \"ON\" : \"OFF\") + \" | Light: \" + (p.pl ? \"ON\" : \"OFF\") };\n\n// Threshold Texts - Force string conversion\nvar txt_sl = { payload: (p.sl || 0) + \"%\" };\nvar txt_sh = { payload: (p.sh || 0) + \"%\" };\nvar txt_tl = { payload: (p.tl || 0) + \"\u00b0C\" };\nvar txt_th = { payload: (p.th || 0) + \"\u00b0C\" };\nvar txt_ll = { payload: (p.ll || 0) + \"%\" };\nvar txt_lh = { payload: (p.lh || 0) + \"%\" };\n\nreturn [\n    msg_h, \n    [msg_s_gauge, ...msg_s_chart], \n    [msg_t_gauge, ...msg_t_chart], \n    [msg_l_gauge, ...msg_l_chart], \n    stat_h, stat_s, stat_t, stat_l, \n    msg_status, msg_dry, msg_wet, \n    txt_sl, txt_sh, txt_tl, txt_th, txt_ll, txt_lh, act_status\n];\n",
        "outputs": 18,
        "x": 300,
        "y": 200,
        "wires": [
            [
                "ui_gauge_health_pro",
                "ui_chart_health_pro"
            ],
            [
                "ui_gauge_soil_pro",
                "ui_chart_soil_pro"
            ],
            [
                "ui_gauge_temp_pro",
                "ui_chart_temp_pro"
            ],
            [
                "ui_gauge_light_pro",
                "ui_chart_light_pro"
            ],
            [],
            [],
            [],
            [],
            [
                "ui_text_status_pro"
            ],
            [
                "ui_text_dry_pro"
            ],
            [
                "ui_text_wet_pro"
            ],
            [
                "ui_text_th_sl"
            ],
            [
                "ui_text_th_sh"
            ],
            [
                "ui_text_th_tl"
            ],
            [
                "ui_text_th_th"
            ],
            [
                "ui_text_th_ll"
            ],
            [
                "ui_text_th_lh"
            ],
            [
                "ui_text_actuators"
            ]
        ]
    },
