    },
    {
        "id": "logic_latency_calc",
        "type": "function",
        "z": "tab_plant_iot_pro",
        "name": "Calculate Latency",
        "func": "\n// If this message came from a UI Button click\nif (msg.topic === \"stm32/commands\") {\n    flow.set(\"last_click_time\", Date.now());\n    return null; // Don't update UI yet\n}\n\n// If this message came from STM32 telemetry (Parse JSON node)\nconst lastClick = flow.get(\"last_click_time\");\nconst lastCmd = msg.payload.c; // The 'C:' value from STM32 JSON\n\nif (lastClick && lastCmd !== \"WAIT\") {\n    const latency = Date.now() - lastClick;\n    flow.set(\"last_click_time\", null); // Reset\n    return { payload: latency };\n}\nreturn null;\n",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 800,
        "y": 300,
        "wires": [
            [
                "ui_text_latency"
            ]
        ]
    }
]