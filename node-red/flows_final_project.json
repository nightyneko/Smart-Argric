    {
        "id": "logic_dynamic_gauges",
        "type": "function",
        "z": "tab_plant_iot_pro",
        "name": "Dynamic Gauge Logic",
        "func": "\n// 1. Get telemetry data\nconst d = msg.payload;\n\n// 2. Ensure we have valid numbers for sensor values\nconst soil_val = parseFloat(d.s);\nconst temp_val = parseFloat(d.t);\nconst light_val = parseFloat(d.l);\n\n// 3. Define Segments (from values MUST be numbers)\nconst sl = parseFloat(d.sl) || 30;\nconst sh = parseFloat(d.sh) || 45;\nconst tl = parseFloat(d.tl) || 25;\nconst th = parseFloat(d.th) || 30;\nconst ll = parseFloat(d.ll) || 20;\nconst lh = parseFloat(d.lh) || 80;\n\nconst soil_segments = [\n    { from: 0, color: \"#ff3b30\" },   // Red (Dry)\n    { from: sl, color: \"#4cd964\" },  // Green (Good)\n    { from: sh, color: \"#ffcc00\" }   // Yellow (Wet)\n];\n\nconst temp_segments = [\n    { from: 0, color: \"#007aff\" },   // Blue (Cold)\n    { from: tl, color: \"#4cd964\" },  // Green (Ideal)\n    { from: th, color: \"#ff3b30\" }   // Red (Hot)\n];\n\nconst light_segments = [\n    { from: 0, color: \"#5856d6\" },   // Purple (Dark)\n    { from: ll, color: \"#4cd964\" },  // Green (Ideal)\n    { from: lh, color: \"#ffcc00\" }   // Yellow (Bright)\n];\n\n// 4. Return separate messages for each gauge\n// We send the REAL VALUE as payload and explicitly set msg.ui_update\nreturn [\n    { payload: soil_val, ui_update: { segments: soil_segments } },\n    { payload: temp_val, ui_update: { segments: temp_segments } },\n    { payload: light_val, ui_update: { segments: light_segments } },\n    { payload: d.h } // Health score\n];\n",
        "outputs": 4,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 600,
        "y": 200,
        "wires": [
            [
                "ui_gauge_soil_pro"
            ],
            [
                "ui_gauge_temp_pro"
            ],
            [
                "ui_gauge_light_pro"
            ],
            [
                "ui_gauge_health_pro"
            ]
        ]
    },
